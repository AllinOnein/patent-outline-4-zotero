{
  "name": "patent-outline-generator",
  "type": "module",
  "version": "1.0.0",
  "description": "Zotero Patent Outline Generator - Automatically generate structured PDF bookmarks from MinerU-parsed patent documents",
  "config": {
    "addonName": "Patent Outline Generator",
    "addonID": "patentplus@patentplus.dev",
    "addonRef": "patentplus",
    "addonInstance": "PatentOutline",
    "prefsPrefix": "extensions.zotero.patentplus"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AllinOnein/patent-outline-4-zotero.git"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/AllinOnein/patent-outline-4-zotero/issues"
  },
  "homepage": "https://github.com/AllinOnein/patent-outline-4-zotero#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "pdf-lib": "^1.17.1",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^10.5.0",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
